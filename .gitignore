# Rust
/target/
**/*.rs.bk

# Local runtime state (the session registry lives in the XDG data dir in real use,
# but keep any dev-time databases out of the repo)
*.db
*.db-journal
*.sqlite
# WAL sidecars carry recently-written row data (including dispatch prompts)
# until a checkpoint folds them into the .db — F-011.
*.db-wal
*.db-shm

# Environment / secrets — this project must never contain credentials
.env
.env.*

# Claude Code local (per-machine, not shared)
CLAUDE.local.md
.claude/settings.local.json

# swarm-tui personal layer (per-machine, not shared — ADR-0012)
.swarm/*.local.json

# Editors & OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
